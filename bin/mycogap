# --- 3 Phyloseq-based community analysis pipeline ---
progress_step(5, "General eukaryotic community outputs")
path3 <- file.path(path_out, "3_phyloseq")
if(!dir.exists(path3)) {dir.create(path3)}

# Construct the phyloseq subject
otu_table <- phyloseq::otu_table(as.matrix(seqtab_cluster), taxa_are_rows = FALSE)

sam_data <- data.frame(row.names = rownames(otu_table), project = rep(project0, nrow(otu_table)))
sam_data <- sample_data(sam_data)

tax_table <- phyloseq::tax_table(as.matrix(tax_cluster))

refseq <- readDNAStringSet(file.path(path2, paste0(project, "ASV_c", vsearch_id*100,".fasta")), format = "fasta")

ps <- phyloseq(otu_table,
               sam_data,
               tax_table,
               refseq)
ps
summarize_phyloseq_logged(ps)

# --- 3.1 Global community analysis and basic filtering ---
path_all <- file.path(path3, "all")
if(!dir.exists(path_all)) dir.create(path_all)

# --- 3.1.1 General filtering ---
# Remove ASVs with unclear phylum annotation
ps_filter <- subset_taxa(ps, Phylum != "NA" & Kingdom != "k__Eukaryota_kgd_Incertae_sedis")

ntaxa(ps)
ntaxa(ps_filter)

# Set ASV counts to 0 in samples where relative abundance is below filter_abundance
otu <- ps_filter@otu_table
otu[otu / rowSums(otu) < filter_abundance] <- 0
otu_table(ps_filter) <- otu # Return otu table to ps
ps_filter <- filter_taxa(ps_filter, function(otu) sum(otu) > 1, TRUE) # Remove ASVs that are all zeros after filtering
ps_filter <- prune_samples(sample_sums(ps_filter) > 0, ps_filter) # Remove samples without any reads

ntaxa(ps)
ntaxa(ps_filter)
nsamples(ps)
nsamples(ps_filter)

# --- 3.1.2 Write output  ---
path_all
saveRDS(ps_filter, file.path(path_all, paste0(project, "ps_all.rds")))
write_readcount(ps_filter, file.path(path_all, paste0(project, "readcount_all.csv")))
writeXStringSet(ps_filter@refseq, file = file.path(path_all, paste0(project, "refseq_all.fasta")), format = "fasta")
write.csv(ps_filter@tax_table, file.path(path_all, paste0(project, "taxa_all.csv")))
write.csv(ps_filter@otu_table, file.path(path_all, paste0(project,"otu_all.csv")))

# Alpha diversity
try({diversity_all <- if (is_verbose) {
       estimate_richness(ps_filter, split = TRUE, measures = c("Observed", "Shannon", "Simpson"))
     } else {
       with_filtered_conditions(
         estimate_richness(ps_filter, split = TRUE, measures = c("Observed", "Shannon", "Simpson")),
         richness_noise_patterns
       )
     }
     write.csv(diversity_all, file.path(path_all, paste0(project, "diversity_all.csv")))
     }, silent = F)


# --- 3.2 Fungal community related ---
progress_step(6, "Microfungi, macrofungi, and plant outputs")
path_microfungi <- file.path(path3, "microfungi")
if(!dir.exists(path_microfungi)) dir.create(path_microfungi)

ps_microfungi <- subset_taxa(ps_filter, Kingdom == "k__Fungi")

# Check
ntaxa(ps_microfungi)
get_taxa_unique(ps_microfungi, "Phylum")
summarize_phyloseq_logged(ps_microfungi)

# --- 3.2.1 Filter macrofungal taxa from the fungal community ---
# Identify macrofungal taxa using the selected strategy
taxa_table <- as.data.frame(ps_microfungi@tax_table)
taxa_table_macrofungi_list <- taxa_table[FALSE, , drop = FALSE]
taxa_table_agaricomycetes <- taxa_table[FALSE, , drop = FALSE]

if (macrofungi_filter %in% c("dual", "list")) {
  macrofungi_genera <- read.csv(macrofungi_list, stringsAsFactors = FALSE)$Genus
  macrofungi_genera <- paste0("g__", macrofungi_genera)
  taxa_table_macrofungi_list <- taxa_table[
    taxa_table$Genus %in% macrofungi_genera, , drop = FALSE
  ]
}

if (macrofungi_filter %in% c("dual", "agaricomycetes")) {
  is_agaricomycetes <- !is.na(taxa_table$Class) & taxa_table$Class == "c__Agaricomycetes"
  taxa_table_agaricomycetes <- taxa_table[is_agaricomycetes, , drop = FALSE]
}

macrofungi_to_exclude <- switch(
  macrofungi_filter,
  dual = union(rownames(taxa_table_macrofungi_list), rownames(taxa_table_agaricomycetes)),
  list = rownames(taxa_table_macrofungi_list),
  agaricomycetes = rownames(taxa_table_agaricomycetes),
  none = character(0)
)

message(paste0("Macrofungal filter '", macrofungi_filter, "' identified ",
               length(macrofungi_to_exclude), " clustered features for exclusion."))

if (length(macrofungi_to_exclude) == 0) {
  ps_microfungi2 <- ps_microfungi
} else {
  ps_microfungi2 <- prune_taxa(
    !(taxa_names(ps_microfungi) %in% macrofungi_to_exclude),
    ps_microfungi
  )
}

# Check
ntaxa(ps_microfungi)
ntaxa(ps_microfungi2)
summarize_phyloseq_logged(ps_microfungi2)

# --- 3.2.2 Write output without read-depth filtering ---
# ASV level output
path_microfungi_ASV <- file.path(path_microfungi, "ASV")
if(!dir.exists(path_microfungi_ASV)) dir.create(path_microfungi_ASV)
path_microfungi_ASV

saveRDS(ps_microfungi2, file.path(path_microfungi_ASV, paste0(project, "ps_microfungi.rds")))
write_readcount(ps_microfungi2, file.path(path_microfungi_ASV, paste0(project, "readcount_microfungi.csv")))
writeXStringSet(ps_microfungi2@refseq, file = file.path(path_microfungi_ASV, paste0(project, "refseq_microfungi.fasta")), format = "fasta")
write.csv(ps_microfungi2@tax_table, file.path(path_microfungi_ASV, paste0(project, "taxa_microfungi.csv")))
write.csv(ps_microfungi2@otu_table, file.path(path_microfungi_ASV, paste0(project,"otu_microfungi.csv")))

# Alpha diversity
try({diversity_microfungi <- if (is_verbose) {
       estimate_richness(ps_microfungi2, split = TRUE, measures = c("Observed", "Shannon", "Simpson"))
     } else {
       with_filtered_conditions(
         estimate_richness(ps_microfungi2, split = TRUE, measures = c("Observed", "Shannon", "Simpson")),
         richness_noise_patterns
       )
     }
     write.csv(diversity_microfungi, file.path(path_microfungi_ASV, paste0(project, "diversity_microfungi.csv")))
     })

# Genus level output
path_microfungi_gen <- file.path(path_microfungi, "genus")
if(!dir.exists(path_microfungi_gen)) dir.create(path_microfungi_gen)
path_microfungi_gen
write_taxonomic_level_outputs(
  ps_microfungi2, "Genus", path_microfungi_gen, "microfungi"
)

# Phylum level output
path_microfungi_phy <- file.path(path_microfungi, "phylum")
if(!dir.exists(path_microfungi_phy)) dir.create(path_microfungi_phy)
path_microfungi_phy
write_taxonomic_level_outputs(
  ps_microfungi2, "Phylum", path_microfungi_phy, "microfungi"
)

# --- 3.2.3 Write output after read-depth filtering ---
# Remove samples with insufficient reads
ps_microfungi_fdp <- prune_samples(sample_sums(ps_microfungi2) >= filter_depth, ps_microfungi2)
ps_microfungi_fdp <- filter_taxa(ps_microfungi_fdp, function(otu) sum(otu) > 1, TRUE) # Remove ASVs that are all zeros after filtering

# Check
ntaxa(ps_microfungi2)
ntaxa(ps_microfungi_fdp)
nsamples(ps_microfungi2)
nsamples(ps_microfungi_fdp)
summarize_phyloseq_logged(ps_microfungi_fdp)

# ASV level output
path_microfungi_ASV <- file.path(path_microfungi, "ASV")
if(!dir.exists(path_microfungi_ASV)) dir.create(path_microfungi_ASV)
path_microfungi_ASV

saveRDS(ps_microfungi_fdp, file.path(path_microfungi_ASV, paste0(project, "ps_microfungi_fdp.rds")))
write_readcount(ps_microfungi_fdp, file.path(path_microfungi_ASV, paste0(project, "readcount_microfungi_fdp.csv")))
writeXStringSet(ps_microfungi_fdp@refseq, file = file.path(path_microfungi_ASV, paste0(project, "refseq_microfungi_fdp.fasta")), format = "fasta")
write.csv(ps_microfungi_fdp@tax_table, file.path(path_microfungi_ASV, paste0(project, "taxa_microfungi_fdp.csv")))
write.csv(ps_microfungi_fdp@otu_table, file.path(path_microfungi_ASV, paste0(project,"otu_microfungi_fdp.csv")))

# Alpha diversity
try({diversity_microfungi_fdp <- if (is_verbose) {
       estimate_richness(ps_microfungi_fdp, split = TRUE, measures = c("Observed", "Shannon", "Simpson"))
     } else {
       with_filtered_conditions(
         estimate_richness(ps_microfungi_fdp, split = TRUE, measures = c("Observed", "Shannon", "Simpson")),
         richness_noise_patterns
       )
     }
     write.csv(diversity_microfungi_fdp, file.path(path_microfungi_ASV, paste0(project, "diversity_microfungi_fdp.csv")))
     })

# Genus level output
path_microfungi_gen <- file.path(path_microfungi, "genus")
if(!dir.exists(path_microfungi_gen)) dir.create(path_microfungi_gen)
path_microfungi_gen
write_taxonomic_level_outputs(
  ps_microfungi_fdp, "Genus", path_microfungi_gen, "microfungi", suffix = "_fdp"
)

# Phylum level output
path_microfungi_phy <- file.path(path_microfungi, "phylum")
if(!dir.exists(path_microfungi_phy)) dir.create(path_microfungi_phy)
path_microfungi_phy
write_taxonomic_level_outputs(
  ps_microfungi_fdp, "Phylum", path_microfungi_phy, "microfungi", suffix = "_fdp"
)


# --- 3.3 Vegetable-related ---
path_vegetable <- file.path(path3, "vegetable")
if(!dir.exists(path_vegetable)) dir.create(path_vegetable)

# --- 3.3.1 Macrofungi-related ---
if (length(macrofungi_to_exclude) == 0) {
  macrofungi_try <- structure("No macrofungal features matched the selected strategy.", class = "try-error")
} else {
  macrofungi_try <- try({
    ps_macrofungi <- prune_taxa(
      taxa_names(ps_microfungi) %in% macrofungi_to_exclude,
      ps_microfungi
    )
  }, silent = !is_verbose)
}

if (inherits(macrofungi_try, "try-error")) {
  message("Note: No macrofungal reads were detected for analysis\n")
} else {
    macrofungi_export_try <- try({
    path_macrofungi <- file.path(path_vegetable, "macrofungi")
    if(!dir.exists(path_macrofungi)) dir.create(path_macrofungi)

    # ASV level out
    path_macrofungi_ASV <- file.path(path_macrofungi, "ASV")
    if(!dir.exists(path_macrofungi_ASV)) dir.create(path_macrofungi_ASV)
    path_macrofungi_ASV

    saveRDS(ps_macrofungi, file.path(path_macrofungi_ASV, paste0(project, "ps_macrofungi.rds")))
    write_readcount(ps_macrofungi, file.path(path_macrofungi_ASV, paste0(project, "readcount_macrofungi.csv")))
    writeXStringSet(ps_macrofungi@refseq, file = file.path(path_macrofungi_ASV, paste0(project, "refseq_macrofungi.fasta")), format = "fasta")
    write.csv(ps_macrofungi@tax_table, file.path(path_macrofungi_ASV, paste0(project, "taxa_macrofungi.csv")))
    write.csv(ps_macrofungi@otu_table, file.path(path_macrofungi_ASV, paste0(project, "otu_macrofungi.csv")))

    # Genus level out
    path_macrofungi_gen <- file.path(path_macrofungi, "genus")
    if(!dir.exists(path_macrofungi_gen)) dir.create(path_macrofungi_gen)
    path_macrofungi_gen
    write_taxonomic_level_outputs(
      ps_macrofungi, "Genus", path_macrofungi_gen, "macrofungi",
      base_taxa_p0 = TRUE
    )

    # Phylum level out
    path_macrofungi_phy <- file.path(path_macrofungi, "phylum")
    if(!dir.exists(path_macrofungi_phy)) dir.create(path_macrofungi_phy)
    path_macrofungi_phy
    write_taxonomic_level_outputs(
      ps_macrofungi, "Phylum", path_macrofungi_phy, "macrofungi",
      base_taxa_p0 = TRUE
    )
    }, silent = !is_verbose)
    if (inherits(macrofungi_export_try, "try-error")) {
      warning("Macrofungal reads were detected, but optional macrofungi outputs could not be completed: ",
              as.character(macrofungi_export_try))
    }
}


# --- 3.3.2 Plant-related ---
plant_try <- try({
  ps_plant <- subset_taxa(ps_filter, Kingdom == "k__Viridiplantae")
}, silent = !is_verbose)

if (inherits(plant_try, "try-error") || ntaxa(ps_plant) == 0) {
  message("Note: No plant reads were detected for analysis\n")
} else {
    plant_export_try <- try({
    path_plant <- file.path(path_vegetable, "plant")
    if(!dir.exists(path_plant)) dir.create(path_plant)

    # ASV level output
    path_plant_ASV <- file.path(path_plant, "ASV")
    if(!dir.exists(path_plant_ASV)) dir.create(path_plant_ASV)
    path_plant_ASV

    saveRDS(ps_plant, file.path(path_plant_ASV, paste0(project, "ps_plant.rds")))
    write_readcount(ps_plant, file.path(path_plant_ASV, paste0(project, "readcount_plant.csv")))
    writeXStringSet(ps_plant@refseq, file = file.path(path_plant_ASV, paste0(project, "refseq_plant.fasta")), format = "fasta")
    write.csv(ps_plant@tax_table, file.path(path_plant_ASV, paste0(project, "taxa_plant.csv")))
    write.csv(ps_plant@otu_table, file.path(path_plant_ASV, paste0(project, "otu_plant.csv")))

    # Genus level output
    path_plant_gen <- file.path(path_plant, "genus")
    if(!dir.exists(path_plant_gen)) dir.create(path_plant_gen)
    path_plant_gen
    write_taxonomic_level_outputs(
      ps_plant, "Genus", path_plant_gen, "plant"
    )

    # Phylum level output
    path_plant_phy <- file.path(path_plant, "phylum")
    if(!dir.exists(path_plant_phy)) dir.create(path_plant_phy)
    path_plant_phy
    write_taxonomic_level_outputs(
      ps_plant, "Phylum", path_plant_phy, "plant"
    )
    }, silent = !is_verbose)
    if (inherits(plant_export_try, "try-error")) {
      warning("Plant reads were detected, but optional plant outputs could not be completed: ",
              as.character(plant_export_try))
    }
}

progress_step(7, "Completed")
options(echo = FALSE)

run_end_time <- Sys.time()
message("===============================================\n")
message("All done!\n")
message(paste0("End at: ", format(run_end_time, "%Y-%m-%d %H:%M:%S")))
message(sprintf("Elapsed time: %.1f seconds\n",
                as.numeric(difftime(run_end_time, run_start_time, units = "secs"))))
message("===============================================\n")

options(error = NULL)
close_run_log()
