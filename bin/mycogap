  "ITSx",
  file.path(path_itsx, paste0(project, "itsx_error.log"))
)

# Determine potential marker based on output file size
itsx_out_files <- c(
  file.path(path_itsx, paste0(project, "asv_itsx.ITS1.fasta")),
  file.path(path_itsx, paste0(project, "asv_itsx.ITS2.fasta")),
  file.path(path_itsx, paste0(project, "asv_itsx.full.fasta"))
)
itsx_out_size <- vapply(itsx_out_files, function(path) {
  if (file.exists(path)) file.info(path)$size else 0
}, numeric(1))

if (all(itsx_out_size == 0)) {
  stop("Error: ITSx completed but produced no non-empty ITS1, ITS2, or full-region FASTA output.")
}

# Select marker with the largest file size
if (which.max(itsx_out_size) == 1) {
  marker_detected <- "ITS1"
} else if (which.max(itsx_out_size) == 2) {
  marker_detected <- "ITS2"
} else {
  marker_detected <- "full"
}

# Decide final marker for downstream analysis
if (marker == "Auto") {
  final_marker <- marker_detected
  message(paste0("Detected marker is ", marker_detected,
                 ". Auto mode selected, so this marker will be used for downstream analysis."))
} else if (marker == marker_detected) {
  final_marker <- marker
  message(paste0("User-selected marker ", marker,
                 " matches the detected marker. Proceeding with ", marker, "."))
} else {
  final_marker <- marker
  message(paste0("Detected marker is ", marker_detected,
                 ", but user-selected marker is ", marker,
                 ". Proceeding with ", marker,
                 ", but please note the difference."))
}

# Load ITSX output sequences (FASTA) corresponding to the final selected marker
selected_itsx_file <- file.path(path_itsx, paste0(project, "asv_itsx.", final_marker, ".fasta"))
if (!file.exists(selected_itsx_file) || file.info(selected_itsx_file)$size == 0) {
  stop(paste0("Error: the selected marker '", final_marker,
              "' has no non-empty ITSx output: ", selected_itsx_file))
}
ASV_itsx <- readDNAStringSet(selected_itsx_file, format = "fasta")
ASV_itsx

