  message(sprintf("| %-76s |", text))
}

print_config_line <- function(label, value) {
  message(sprintf("| %-34s : %s", label, value))
}

prevalence_display <- if (length(prevalence_thresholds) == 0) {
  "none (unfiltered p0 outputs only)"
} else {
  paste0(
    format(prevalence_thresholds * 100, trim = TRUE, scientific = FALSE),
    "%",
    collapse = ", "
  )
}

message("\n+------------------------------------------------------------------------------+")
print_banner_line("")
print_banner_line("                              MycoGAP 1.7.0")
print_banner_line("                 Accurate, human gut-focused, ITS-aware workflow")
print_banner_line("              Standardized analysis of heterogeneous datasets")
print_banner_line("")
message("+------------------------------------------------------------------------------+")
print_banner_line("Author      : Xinyu Wang")
print_banner_line("Affiliation : Westlake University")
print_banner_line("GitHub      : https://github.com/WeStrainGroup/MycoGAP")
print_banner_line("Contact     : wangxinyu30 [at] westlake.edu.cn")
message("+------------------------------------------------------------------------------+")

message("\n+-- RUN CONFIGURATION ---------------------------------------------------------+")
message("| Please verify the effective settings below before analysis begins.")
message("|")
print_config_line("Project", project0)
print_config_line("Input directory", path_in)
print_config_line("Output directory", path_out)
print_config_line("Sequencing type", seq_type)
print_config_line("Marker gene", marker)
print_config_line("Forward reads pattern", pattern_F)
print_config_line("Reverse reads pattern", pattern_R)
