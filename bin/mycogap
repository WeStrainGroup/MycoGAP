#!/usr/bin/env Rscript


# --- 0 General Preparation ---
# --- 0.1 Command line argument parsing and validation ---
library(optparse)

get_script_file <- function() {
  file_arg <- grep("^--file=", commandArgs(trailingOnly = FALSE), value = TRUE)
  if (length(file_arg) == 0) return(NA_character_)
  normalizePath(sub("^--file=", "", file_arg[[1]]), mustWork = FALSE)
}

script_file <- get_script_file()
script_dir <- if (is.na(script_file)) getwd() else dirname(script_file)
install_prefix <- normalizePath(file.path(script_dir, ".."), mustWork = FALSE)
conda_prefix <- Sys.getenv("CONDA_PREFIX", unset = "")

ref_dirs <- unique(c(
  normalizePath(file.path(script_dir, "..", "ref"), mustWork = FALSE),
  file.path(install_prefix, "lib/R/library/mycogap/ref"),
  if (nzchar(conda_prefix)) file.path(conda_prefix, "lib/R/library/mycogap/ref") else character(0)
))

resolve_packaged_ref <- function(filename) {
  candidates <- file.path(ref_dirs, filename)
  existing <- candidates[file.exists(candidates)]
  if (length(existing) > 0) existing[[1]] else candidates[[1]]
}

default_unite_ref <- resolve_packaged_ref("sh_general_release_dynamic_all_19.02.2025.fasta.gz")
default_macrofungi_list <- resolve_packaged_ref("macrofungi_list.csv")

option_list <- list(
  make_option("--project", type = "character",
              help = "Project name (used as prefix for key output files)"),
  make_option("--input", type = "character",
              help = "Path to folder containing FASTQ files to process"),
  make_option("--output", type = "character",
              help = "Path to folder for output"),
  make_option("--seq_type", type = "character", default = 'PE',
              help = "Sequencing type: 'PE' for paired-end, 'SE' for single-end, or 'PB' for PacBio. [default: %default]"),
  make_option("--marker", type = "character", default = 'Auto',
              help = "Marker gene sequenced: 'ITS1', 'ITS2', or 'full'; 'Auto' for automatic detection. [default: %default]"),
  make_option("--pattern_f", type = "character",
              help = "Pattern to match forward reads (e.g., '.1.fq.gz' for PE, or '.fq.gz' for SE / PB)"),
  make_option("--pattern_r", type = "character",
              help = "Pattern to match reverse reads (e.g., '.2.fq.gz'). For SE / PB, must be identical to --pattern_f"),
  make_option("--maxee_f", type = "numeric", default = 5,
              help = "Maximum expected errors used by DADA2 filterAndTrim function for forward reads [default: %default]"),
  make_option("--maxee_r", type = "numeric", default = 5,
              help = "Maximum expected errors for reverse reads. For SE / PB, must be identical to --maxee_f [default: %default]"),
  make_option("--itsx_e", type = "numeric", default = 0.01,
              help = "E-value cutoff for domain hits in the HMMER step of ITSx [default: %default]"),
  make_option("--ref", type = "character",
              default = default_unite_ref,
              help = "Path to reference database for taxonomic assignment [default: UNITE (10.0, all eukaryotes, dynamic)]"),
  make_option("--macrofungi_list", type = "character",
              default = default_macrofungi_list,
              help = "Path to curated macrofungal genus list [default: packaged macrofungi_list.csv]"),
  make_option("--macrofungi_filter", type = "character", default = "dual",
              help = "Macrofungal filtering strategy: 'dual', 'list', 'agaricomycetes', or 'none'. 'agar' is accepted as an alias for 'agaricomycetes'. [default: %default]"),
  make_option("--minboot", type = "numeric", default = 50,
              help = "Minimum bootstrap confidence for taxonomic assignment [default: %default]"),
  make_option("--vsearch_id", type = "numeric", default = 0.985,
              help = "Identity threshold for VSEARCH clustering [default: %default]"),
  make_option("--filter_abundance", type = "numeric", default = 1/10000,
              help = "ASVs whose relative abundance in a sample falls below this threshold will be set to zero in that sample [default: %default]"),
  make_option("--filter_depth", type = "numeric", default = 5000,
              help = "Samples with fewer usable reads than this threshold will be excluded from downstream analysis [default: %default]"),
  make_option("--prev_filter", type = "character", default = "none",
              help = "Genus/phylum prevalence filtering: 'none', 'standard' (0.01,0.05,0.10), or comma-separated fractions such as 0.02,0.05 [default: %default]"),
  make_option("--clr", type = "character", default = "F",
              help = "Write CLR-transformed p0 and selected prevalence tables: 'T' or 'F' [default: %default]"),
  make_option("--thread", type = "numeric", default = 8,
              help = "Number of threads to use for parallel computation [default: %default]"),
  make_option("--log_mode", type = "character", default = "progress",
              help = "Logging mode: 'progress' for concise step progress or 'verbose' for detailed R and external-tool output [default: %default]")
)

opt_parser <- OptionParser(option_list = option_list)
opt <- parse_args(opt_parser)

# Check for required arguments
required_args <- c("project", "input", "output", "pattern_f", "pattern_r", "marker")
for (arg in required_args) {
  if (is.null(opt[[arg]])) {
    stop(paste0("Error: --", arg, " is required"))
  }
}

# Expand user-home notation in paths
opt$input <- path.expand(opt$input)
opt$output <- path.expand(opt$output)
opt$ref <- path.expand(opt$ref)
opt$macrofungi_list <- path.expand(opt$macrofungi_list)

if (opt$macrofungi_filter == "agar") opt$macrofungi_filter <- "agaricomycetes"

# Ensure output directory exists
if (!dir.exists(opt$output)) {
  dir.create(opt$output, recursive = TRUE, mode = "0755")
}

# Keep one run-level log while continuing to show output in the terminal.
# Progress mode discards routine R object printing; verbose mode records it.
project_log <- file.path(opt$output, paste0(opt$project, ".log"))
log_mode <- opt$log_mode
is_verbose <- identical(log_mode, "verbose")
tee <- Sys.which("tee")
if (!nzchar(tee)) stop("Error: tee not found in PATH; it is required for run logging.")

writeLines(character(0), project_log)
if (is_verbose && !is.na(script_file) && file.exists(script_file)) {
  script_lines <- readLines(script_file, warn = FALSE)
  cat("===== MycoGAP executed source =====\n", file = project_log, append = TRUE)
  cat(paste(script_lines, collapse = "\n"), "\n", sep = "", file = project_log, append = TRUE)
  cat("===== Runtime output =====\n", file = project_log, append = TRUE)
}
tee_command <- paste(shQuote(tee), "-a", shQuote(project_log))
message_log_connection <- pipe(tee_command, open = "w")
output_log_connection <- NULL
progress_output_connection <- NULL
if (is_verbose) {
  output_log_connection <- file(project_log, open = "at")
  sink(output_log_connection, type = "output", split = TRUE)
} else {
  null_device <- if (.Platform$OS.type == "windows") "NUL" else "/dev/null"
  progress_output_connection <- file(null_device, open = "w")
  sink(progress_output_connection, type = "output")
}
sink(message_log_connection, type = "message")
options(echo = is_verbose)

logging_closed <- FALSE
close_run_log <- function() {
  if (logging_closed) return(invisible(NULL))

  options(echo = FALSE)
  sink(type = "message")
  sink(type = "output")
  if (!is.null(progress_output_connection)) close(progress_output_connection)
  if (!is.null(output_log_connection)) close(output_log_connection)
  close(message_log_connection)
  logging_closed <<- TRUE
  invisible(NULL)
}

# Uncaught errors are printed before this handler runs. Closing the logging
# connections here flushes both that error and all preceding verbose output,
# then quit explicitly so top-level execution cannot continue after failure.
options(error = function() {
  close_run_log()
  quit(save = "no", status = 1, runLast = FALSE)
})

# Validate seq_type input
allowed_seq_types <- c("PE", "SE", "PB")
if (!(opt$seq_type %in% allowed_seq_types)) {
  stop(paste0("Error: --seq_type must be one of: ", paste(allowed_seq_types, collapse = ", ")))
}

allowed_markers <- c("Auto", "ITS1", "ITS2", "full")
if (!(opt$marker %in% allowed_markers)) {
  stop(paste0("Error: --marker must be one of: ", paste(allowed_markers, collapse = ", ")))
}

allowed_macrofungi_filters <- c("dual", "list", "agaricomycetes", "none")
if (!(opt$macrofungi_filter %in% allowed_macrofungi_filters)) {
  stop(paste0("Error: --macrofungi_filter must be one of: ",
              paste(allowed_macrofungi_filters, collapse = ", ")))
}

allowed_log_modes <- c("progress", "verbose")
if (!(opt$log_mode %in% allowed_log_modes)) {
  stop(paste0("Error: --log_mode must be one of: ", paste(allowed_log_modes, collapse = ", ")))
}

parse_prevalence_thresholds <- function(value) {
  if (length(value) != 1 || is.na(value) || !nzchar(trimws(value))) {
    stop("Error: --prev_filter must be 'none', 'standard', or comma-separated fractions in (0, 1].")
  }

  normalized <- tolower(trimws(value))
  if (normalized == "none") return(numeric(0))
  if (normalized == "standard") return(c(0.01, 0.05, 0.10))
  if (normalized == "default") {
    stop("Error: --prev_filter 'default' is not a profile name; use 'standard' for 0.01,0.05,0.10 or 'none' for the default behavior.")
  }

  fields <- trimws(strsplit(value, ",", fixed = TRUE)[[1]])
  thresholds <- suppressWarnings(as.numeric(fields))
  if (any(!nzchar(fields)) || any(!is.finite(thresholds)) ||
      any(thresholds <= 0 | thresholds > 1)) {
    stop("Error: custom --prev_filter values must be comma-separated fractions in (0, 1], for example 0.02,0.05.")
  }
  sort(unique(thresholds))
}

prevalence_thresholds <- parse_prevalence_thresholds(opt$prev_filter)

parse_tf <- function(value, name) {
  if (length(value) != 1 || is.na(value)) {
    stop(paste0("Error: --", name, " must be 'T' or 'F'."))
  }
  normalized <- toupper(trimws(value))
  if (!(normalized %in% c("T", "F"))) {
    stop(paste0("Error: --", name, " must be 'T' or 'F'."))
  }
  identical(normalized, "T")
}

clr_output <- parse_tf(opt$clr, "clr")

validate_number <- function(value, name, lower, upper = Inf, integer = FALSE) {
  if (length(value) != 1 || !is.finite(value) || value < lower || value > upper ||
      (integer && value != as.integer(value))) {
    interval <- if (is.finite(upper)) paste0("[", lower, ", ", upper, "]") else paste0(">= ", lower)
    stop(paste0("Error: --", name, " must be ", if (integer) "an integer " else "", interval))
  }
}

validate_number(opt$maxee_f, "maxee_f", 0)
validate_number(opt$maxee_r, "maxee_r", 0)
validate_number(opt$itsx_e, "itsx_e", 0)
validate_number(opt$minboot, "minboot", 0, 100)
validate_number(opt$vsearch_id, "vsearch_id", 0, 1)
validate_number(opt$filter_abundance, "filter_abundance", 0, 1)
validate_number(opt$filter_depth, "filter_depth", 0, Inf, integer = TRUE)
validate_number(opt$thread, "thread", 1, Inf, integer = TRUE)

if (!dir.exists(opt$input)) stop(paste0("Error: input directory does not exist: ", opt$input))
if (!file.exists(opt$ref)) stop(paste0("Error: taxonomy reference database does not exist: ", opt$ref))
if (opt$macrofungi_filter %in% c("dual", "list") && !file.exists(opt$macrofungi_list)) {
  stop(paste0("Error: macrofungal genus list does not exist: ", opt$macrofungi_list))
}

# Ensure pattern_f and pattern_r are identical unless seq_type is PE
if (opt$seq_type != "PE" && opt$pattern_f != opt$pattern_r) {
  stop("Error: --pattern_f and --pattern_r must be identical unless --seq_type is PE")
}

# Ensure pattern_f and pattern_r are identical unless seq_type is PE
if (opt$seq_type != "PE" && opt$maxee_f != opt$maxee_r) {
  stop("Error: --maxee_f and --maxee_r must be identical unless --seq_type is PE")
}



# Pass parameters to R script
project0 <- opt$project
project <- paste0(project0, "_")
path_in <- opt$input
path_out <- opt$output
seq_type <- opt$seq_type
marker <- opt$marker
pattern_F <- opt$pattern_f
pattern_R <- opt$pattern_r
maxEE_F <- opt$maxee_f
maxEE_R <- opt$maxee_r
itsx_e <- opt$itsx_e
ref <- opt$ref
macrofungi_list <- opt$macrofungi_list
macrofungi_filter <- opt$macrofungi_filter
minBoot <- opt$minboot
vsearch_id <- opt$vsearch_id
filter_abundance <- opt$filter_abundance
filter_depth <- opt$filter_depth
thread <- opt$thread

