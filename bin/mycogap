# Set ITSx environment variable
itsx_bin <- dirname(itsx)
Sys.setenv(PATH = paste(Sys.getenv("PATH"), itsx_bin, sep = ":"))

# Check if required tools exist
check_tool <- function(tool, name) {
  if (tool == "") {
    stop(paste0("Error: ", name, " not found in PATH. Ensure it is installed via Conda."))
  }
}
check_tool(seqkit, "seqkit")
check_tool(itsx, "ITSx")
check_tool(vsearch, "vsearch")

with_filtered_conditions <- function(expr, patterns) {
  expr <- substitute(expr)
  should_muffle <- function(condition) {
    any(vapply(patterns, grepl, logical(1), x = conditionMessage(condition), perl = TRUE))
  }

  withCallingHandlers(
    eval.parent(expr),
    message = function(condition) {
      if (should_muffle(condition)) invokeRestart("muffleMessage")
    },
    warning = function(condition) {
      if (should_muffle(condition)) invokeRestart("muffleWarning")
    }
  )
}

plot_noise_patterns <- c(
  "^`stat_bin\\(\\)` using `bins = 30`",
  "log-10 transformation introduced infinite values",
  "^Removed [0-9]+ rows containing missing values or values outside the scale range"
)
duplicate_sequence_patterns <- c(
  "^Duplicate sequences in merged output\\.$",
  "^Duplicate sequences detected and merged\\.$"
)
richness_noise_patterns <- c(
  "^The data you have provided does not have\\nany singletons\\."
)

save_plot <- function(...) {
  if (is_verbose) return(ggsave(...))
  with_filtered_conditions(ggsave(...), plot_noise_patterns)
}

write_readcount <- function(object, file) {
  counts_raw <- readcount(object)
  sample_ids <- names(counts_raw)
  if (is.null(sample_ids)) sample_ids <- rownames(as.matrix(counts_raw))
  if (is.null(sample_ids)) sample_ids <- sample_names(object)

  counts <- as.numeric(counts_raw)
  if (length(counts) != length(sample_ids)) {
    stop("Error: readcount values could not be aligned with sample names.")
  }

  count_table <- data.frame(
    readcount = counts,
    row.names = sample_ids,
    check.names = FALSE
  )
  write.csv(count_table, file)
}

prevalence_file_tag <- function(threshold) {
  percent <- sprintf("%.10f", threshold * 100)
  percent <- sub("0+$", "", percent)
  percent <- sub("\\.$", "", percent)
  paste0("p", percent)
}

write_taxonomic_level_outputs <- function(object, level, path, category,
                                          suffix = "", base_taxa_p0 = FALSE,
                                          include_clr = clr_output) {
  level_tag <- switch(
    level,
    Genus = "gen",
    Phylum = "phy",
    stop(paste0("Error: unsupported taxonomic output level: ", level))
  )

  base_object <- aggregate_taxa(object, level = level)
  base_taxa_tag <- if (base_taxa_p0) "_p0" else ""
  write.csv(
    base_object@tax_table,
    file.path(path, paste0(project, "taxa_", category, "_", level_tag,
                           base_taxa_tag, suffix, ".csv"))
  )
  write.csv(
    base_object@otu_table,
    file.path(path, paste0(project, "otu_", category, "_", level_tag,
                           "_p0", suffix, ".csv"))
  )
  if (include_clr) {
    base_clr <- vegan::decostand(
      base_object@otu_table,
      MARGIN = 2,
      method = "clr",
      pseudocount = 1
    )
    write.csv(
      base_clr,
      file.path(path, paste0(project, "otu_", category, "_", level_tag,
                             "_p0_clr", suffix, ".csv"))
    )
  }

  for (threshold in prevalence_thresholds) {
    threshold_tag <- prevalence_file_tag(threshold)
    filtered_object <- aggregate_rare(
      object,
      level = level,
      detection = 0,
      prevalence = threshold
    )
    write.csv(
      filtered_object@tax_table,
      file.path(path, paste0(project, "taxa_", category, "_", level_tag,
                             "_", threshold_tag, suffix, ".csv"))
    )
    write.csv(
      filtered_object@otu_table,
      file.path(path, paste0(project, "otu_", category, "_", level_tag,
                             "_", threshold_tag, suffix, ".csv"))
    )
    if (include_clr) {
      filtered_clr <- vegan::decostand(
        filtered_object@otu_table,
        MARGIN = 2,
        method = "clr",
        pseudocount = 1
      )
      write.csv(
        filtered_clr,
        file.path(path, paste0(project, "otu_", category, "_", level_tag,
                               "_", threshold_tag, "_clr", suffix, ".csv"))
      )
    }
  }

  invisible(NULL)
}

summarize_phyloseq_logged <- function(object) {
  if (is_verbose) {
    return(microbiome::summarize_phyloseq(object))
  }

  result <- withCallingHandlers(
    microbiome::summarize_phyloseq(object),
    message = function(condition) {
      invokeRestart("muffleMessage")
    }
  )
  invisible(result)
}

progress_total <- 7L
progress_step <- function(step, label) {
  current_time <- format(Sys.time(), "%Y-%m-%d %H:%M:%S")
  if (step == progress_total) {
    message(sprintf("[%d/%d] %s | Time: %s", step, progress_total, label, current_time))
  } else {
    message(sprintf("[%d/%d] %s | Start: %s", step, progress_total, label, current_time))
  }
  invisible(NULL)
}

run_seqkit_stats <- function(args) {
  stderr_file <- tempfile(pattern = "seqkit_stderr_", fileext = ".log")
  on.exit(if (file.exists(stderr_file)) unlink(stderr_file), add = TRUE)

  output <- system2(seqkit, args = args, stdout = TRUE, stderr = stderr_file)
  status <- attr(output, "status")
  if (is.null(status)) status <- 0L
  stderr_output <- if (file.exists(stderr_file)) readLines(stderr_file, warn = FALSE) else character(0)

  if (is_verbose && length(stderr_output) > 0) {
    cat(paste(stderr_output, collapse = "\n"), "\n", sep = "")
  }
  if (status != 0L) {
    detail <- tail(stderr_output, 20)
    stop(paste(c("Error: seqkit stats failed.", detail), collapse = "\n"))
  }
  output
}

run_external_tool <- function(command, args, label, error_log) {
  output <- suppressWarnings(system2(command, args = args, stdout = TRUE, stderr = TRUE))
  status <- attr(output, "status")
  if (is.null(status)) status <- 0L

  if (is_verbose && length(output) > 0) {
    cat(paste(output, collapse = "\n"), "\n", sep = "")
  }

  if (status != 0L) {
    diagnostic <- c(
      paste0(label, " failed with exit status ", status, "."),
      output
    )
    writeLines(diagnostic, error_log, useBytes = TRUE)
    detail <- tail(output, 20)
    stop(paste(c(
      paste0("Error: ", label, " failed with exit status ", status, "."),
      paste0("Full diagnostic output: ", error_log),
      detail
    ), collapse = "\n"))
  }
  invisible(status)
}

# --- 0.4 Function definitions for quality control and visualization ---
# Define function for FASTQ quality assessment and statistics
check_fq_stats <- function(F, R, batch_size = 1000) {
    title <- paste0(project, "fq_stats_", sub(".*_", "", substitute(F)))
    all_files <- sort(unique(c(F, R)))
    p_out <- file.path(path_check, paste0(title, ".tsv"))

    # Batch division
    file_batches <- split(all_files, ceiling(seq_along(all_files) / batch_size))

    # Temporary result file list
    temp_outputs <- character(length(file_batches))

    for (i in seq_along(file_batches)) {
        batch_files <- file_batches[[i]]
        temp_out <- tempfile(pattern = paste0("fq_stats_batch_", i), fileext = ".tsv")
        temp_outputs[i] <- temp_out

        arg_seqkit <- c("stats", "-a", "-b", "-e", "-T", "-j", thread, batch_files)
        out <- run_seqkit_stats(arg_seqkit)
        writeLines(out, temp_out)
    }

    # Merge all results and save
    df_list <- lapply(temp_outputs, read.delim, header = TRUE)
    fa_raw_check <- do.call(rbind, df_list)
    write.table(fa_raw_check, file = p_out, sep = "\t", row.names = FALSE, quote = FALSE)

    # Plot
    his1 <- ggplot(fa_raw_check, aes(x = num_seqs)) +
        geom_histogram(aes(y = after_stat(count)/sum(after_stat(count))),
                       fill = "grey", color = "black", alpha = 0.75) +
        labs(title = title,
             x = "Num_seqs of each sample",
             y = "Proportion") +
        theme_bw()

    save_plot(file.path(path_check, paste0(title, "1.jpg")), his1, width = 6, height = 6)

    his2 <- ggplot(fa_raw_check, aes(x = avg_len)) +
            geom_histogram(aes(y = after_stat(count)/sum(after_stat(count))), fill = "grey", color = "black", alpha = 0.75) +
            labs(title = title,
                x = "Avg_len of each sample",
                y = "Proportion") +
            theme_bw()
      save_plot(file.path(path_check,  paste0(title, "2.jpg")), his2, width = 6, height = 6)

    his3 <- ggplot(fa_raw_check, aes(x = AvgQual)) +
            geom_histogram(aes(y = after_stat(count)/sum(after_stat(count))), fill = "grey", color = "black", alpha = 0.75) +
            labs(title = title,
                x = "Avg_qual of each sample",
                y = "Proportion") +
            theme_bw()
    save_plot(file.path(path_check, paste0(title, "3.jpg")), his3, width = 6, height = 6)
}

# Define function for quality profile visualization and export
if (seq_type == 'PE') {
    save_quality_plot <- function(fq_F, fq_R) {
    title_F <- paste0(project, "quality_", substitute(fq_F))
    title_R <- paste0(project, "quality_", substitute(fq_R))

    p_quality_R1 <- plotQualityProfile(fq_F[seq_len(min(9, length(fq_F)))]) + labs(title = title_F)
    p_quality_R2 <- plotQualityProfile(fq_R[seq_len(min(9, length(fq_R)))]) + labs(title = title_R)

    save_plot(file.path(path_check, paste0(title_F, ".jpg")), p_quality_R1, width = 6, height = 6)
    save_plot(file.path(path_check, paste0(title_R, ".jpg")), p_quality_R2, width = 6, height = 6)
  }
} else {
    save_quality_plot <- function(fq) {
    title <- paste0(project, "quality_", substitute(fq))
    p_quality <- plotQualityProfile(fq[seq_len(min(9, length(fq)))]) + labs(title = title)
    save_plot(file.path(path_check, paste0(title, ".jpg")), p_quality, width = 6, height = 6)
  }
}

validate_fastq_files <- function(files, label) {
  if (length(files) == 0) {
    stop(paste0("Error: no ", label, " FASTQ files matched the supplied pattern in ", path_in))
  }
  if (anyDuplicated(basename(files))) {
    stop(paste0("Error: duplicated ", label, " FASTQ basenames were detected."))
  }
  invisible(files)
}

validate_paired_fastq_files <- function(forward, reverse) {
  validate_fastq_files(forward, "forward")
  validate_fastq_files(reverse, "reverse")
  if (length(forward) != length(reverse)) {
    stop(paste0("Error: found ", length(forward), " forward files but ",
                length(reverse), " reverse files."))
  }

  forward_ids <- gsub(pattern_F, "", basename(forward))
  reverse_ids <- gsub(pattern_R, "", basename(reverse))
  if (!identical(forward_ids, reverse_ids)) {
    mismatch <- which(forward_ids != reverse_ids)[[1]]
    stop(paste0("Error: paired FASTQ names do not match at sorted position ", mismatch,
                ": '", basename(forward[[mismatch]]), "' versus '",
                basename(reverse[[mismatch]]), "'."))
  }
  invisible(TRUE)
}


run_start_time <- Sys.time()

# --- 1 DADA2-based sequence processing pipeline ---
progress_step(1, "Read filtering and ASV inference")
path1 <- file.path(path_out, "1_dada2")
if(!dir.exists(path1)) {dir.create(path1)}

if (seq_type == 'PE') {
  # Input FASTQ files
  fqF_raw <- sort(list.files(path_in, pattern = pattern_F, full.names = TRUE))
  fqR_raw <- sort(list.files(path_in, pattern = pattern_R, full.names = TRUE))
  validate_paired_fastq_files(fqF_raw, fqR_raw)

  length(fqF_raw)
  head(fqF_raw)
  length(fqR_raw)
  head(fqR_raw)

  path_check <- file.path(path1, "check")
  if(!dir.exists(path_check)) {dir.create(path_check)}

  check_fq_stats(fqF_raw, fqR_raw)
  save_quality_plot(fqF_raw, fqR_raw)

  # --- 1.1 Quality filtering and trimming using DADA2 ---
  path_filtered <- file.path(path1, "filtered")
  if(!dir.exists(path_filtered)) dir.create(path_filtered)

  fqF_filtered <- file.path(path_filtered, basename(fqF_raw))
  fqR_filtered <- file.path(path_filtered, basename(fqR_raw))

  out <- filterAndTrim(fqF_raw, fqF_filtered, fqR_raw, fqR_filtered,
                      truncQ = 2, maxN = 0, maxEE = c(maxEE_F, maxEE_R),
                      rm.phix = TRUE, compress = T, multithread = thread, verbose = is_verbose)

  rownames(out) <- gsub(pattern_F, "", rownames(out))
  head(out)

  # Keep only FASTQ files with reads
  fqF_filtered <- sort(list.files(path_filtered, pattern = pattern_F, full.names = TRUE))
  fqR_filtered <- sort(list.files(path_filtered, pattern = pattern_R, full.names = TRUE))

  # Check
  check_fq_stats(fqF_filtered, fqR_filtered)
  save_quality_plot(fqF_filtered, fqR_filtered)

  # --- 1.2 DADA2 error rate estimation and denoising ---
  # Learn the Error Rates
  errF <- learnErrors(fqF_filtered, nbases = 1e9, randomize = TRUE, multithread = thread, verbose = is_verbose)
  errR <- learnErrors(fqR_filtered, nbases = 1e9, randomize = TRUE, multithread = thread, verbose = is_verbose)

  # Plot error rates
  p_error_F <- plotErrors(errF, nominalQ = TRUE) + labs(title = paste0(project, "error_F"))
  p_error_R <- plotErrors(errR, nominalQ = TRUE) + labs(title = paste0(project, "error_R"))

  save_plot(file.path(path_check, paste0(project, "error_F.png")), p_error_F, width = 6, height = 6)
  save_plot(file.path(path_check, paste0(project, "error_R.png")), p_error_R, width = 6, height = 6)

  # Sample inference to the de-replicated data
  dadaFs <- dada(fqF_filtered, err = errF, multithread = thread, verbose = is_verbose)
  dadaRs <- dada(fqR_filtered, err = errR, multithread = thread, verbose = is_verbose)

  dadaFs[[1]]
  dadaRs[[1]]

  # --- 1.3 Paired-end read merging and ASV table construction ---
  # Merge paired reads
  mergers <- if (is_verbose) {
    mergePairs(dadaFs, fqF_filtered, dadaRs, fqR_filtered, trimOverhang = TRUE, verbose = TRUE)
  } else {
    with_filtered_conditions(
      mergePairs(dadaFs, fqF_filtered, dadaRs, fqR_filtered, trimOverhang = TRUE, verbose = FALSE),
      duplicate_sequence_patterns
    )
  }
  head(mergers[[1]])

  # Construct sequence (ASV) table
  seqtab <- if (is_verbose) {
    makeSequenceTable(mergers)
  } else {
    with_filtered_conditions(makeSequenceTable(mergers), duplicate_sequence_patterns)
  }
  rownames(seqtab) <- gsub(pattern_F, "", rownames(seqtab))

  dim(seqtab)
  table(nchar(getSequences(seqtab))) # Inspect distribution of sequence lengths

  # Write output
  path_result <- file.path(path1, "result")
  if(!dir.exists(path_result)) dir.create(path_result)

  write.csv(seqtab, file = file.path(path_result, paste0(project, "seqtab_raw.csv")))

} else if (seq_type == 'SE') {

  # Input FASTQ files
  fq_raw <- sort(list.files(path_in, pattern = pattern_F, full.names = TRUE))
  validate_fastq_files(fq_raw, "single-end")

  length(fq_raw)
  head(fq_raw)

  path_check <- file.path(path1, "check")
  if(!dir.exists(path_check)) {dir.create(path_check)}

  check_fq_stats(fq_raw, fq_raw)
  save_quality_plot(fq_raw)

  # --- 1.1 Quality filtering and trimming using DADA2 ---
  path_filtered <- file.path(path1, "filtered")
  if(!dir.exists(path_filtered)) dir.create(path_filtered)

  fq_filtered <- file.path(path_filtered, basename(fq_raw))

  out <- filterAndTrim(fq_raw, fq_filtered,
                      truncQ = 2, maxN = 0, maxEE = maxEE_F,
                      rm.phix = TRUE, compress = T, multithread = thread, verbose = is_verbose)

  rownames(out) <- gsub(pattern_F, "", rownames(out))
  head(out)

  # Keep only FASTQ files with reads
  fq_filtered <- sort(list.files(path_filtered, pattern = pattern_F, full.names = TRUE))

  # Check
  check_fq_stats(fq_filtered, fq_filtered)
  save_quality_plot(fq_filtered)

  # --- 1.2 DADA2 error rate estimation and denoising ---
  # Learn the Error Rates
  err <- learnErrors(fq_filtered, nbases = 1e9, randomize = TRUE, multithread = thread, verbose = is_verbose)

  # Plot error rates
  p_error <- plotErrors(err, nominalQ = TRUE) + labs(title = paste0(project, "error"))
  save_plot(file.path(path_check, paste0(project, "error.png")), p_error, width = 6, height = 6)

  # Sample inference to the de-replicated data
  dada <- dada(fq_filtered, err = err, multithread = thread, verbose = is_verbose)
  dada[[1]]

  # --- 1.3 ASV table construction ---
  seqtab <- if (is_verbose) {
    makeSequenceTable(dada)
  } else {
    with_filtered_conditions(makeSequenceTable(dada), duplicate_sequence_patterns)
  }
  rownames(seqtab) <- gsub(pattern_F, "", rownames(seqtab))

  dim(seqtab)
  table(nchar(getSequences(seqtab))) # Inspect distribution of sequence lengths

  # Write output
  path_result <- file.path(path1, "result")
  if(!dir.exists(path_result)) dir.create(path_result)

  write.csv(seqtab, file = file.path(path_result, paste0(project, "seqtab_raw.csv")))

} else if (seq_type == 'PB') {

  # Input FASTQ files
  fq_raw <- sort(list.files(path_in, pattern = pattern_F, full.names = TRUE))
  validate_fastq_files(fq_raw, "PacBio")

  length(fq_raw)
  head(fq_raw)

  path_check <- file.path(path1, "check")
  if(!dir.exists(path_check)) {dir.create(path_check)}

  check_fq_stats(fq_raw, fq_raw)
  save_quality_plot(fq_raw)

  # --- 1.1 Quality filtering and trimming using DADA2 ---
  path_filtered <- file.path(path1, "filtered")
  if(!dir.exists(path_filtered)) dir.create(path_filtered)

  fq_filtered <- file.path(path_filtered, basename(fq_raw))

  out <- filterAndTrim(fq_raw, fq_filtered,
                      truncQ = 2, maxN = 0, maxEE = maxEE_F,
                      rm.phix = TRUE, compress = T, multithread = thread, verbose = is_verbose)

  rownames(out) <- gsub(pattern_F, "", rownames(out))
  head(out)

  # Keep only FASTQ files with reads
  fq_filtered <- sort(list.files(path_filtered, pattern = pattern_F, full.names = TRUE))

  # Check
  check_fq_stats(fq_filtered, fq_filtered)
  save_quality_plot(fq_filtered)

  # --- 1.2 DADA2 error rate estimation and denoising ---
  # Learn the Error Rates
  err <- learnErrors(fq_filtered, nbases = 1e9, errorEstimationFunction=PacBioErrfun,
                     randomize = TRUE, multithread = thread, verbose = is_verbose) # PB-specific

  # Plot error rates
  p_error <- plotErrors(err, nominalQ = TRUE) + labs(title = paste0(project, "error"))
  save_plot(file.path(path_check, paste0(project, "error.png")), p_error, width = 6, height = 6)

  # Sample inference to the de-replicated data
  dada <- dada(fq_filtered, err = err, multithread = thread, verbose = is_verbose)
  dada[[1]]

  # --- 1.3 ASV table construction ---
  seqtab <- if (is_verbose) {
    makeSequenceTable(dada)
  } else {
    with_filtered_conditions(makeSequenceTable(dada), duplicate_sequence_patterns)
  }
  rownames(seqtab) <- gsub(pattern_F, "", rownames(seqtab))

  dim(seqtab)
  table(nchar(getSequences(seqtab))) # Inspect distribution of sequence lengths

  # Write output
  path_result <- file.path(path1, "result")
  if(!dir.exists(path_result)) dir.create(path_result)

  write.csv(seqtab, file = file.path(path_result, paste0(project, "seqtab_raw.csv")))

}

if (!exists("seqtab") || nrow(seqtab) == 0 || ncol(seqtab) == 0 || sum(seqtab) == 0) {
  stop("Error: DADA2 produced an empty sequence table; no downstream analysis can be performed.")
}

